{
  "name": "portfolio-live-dashboard",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.15.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "WATCHPACK_POLLING=true NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs next dev",
    "build": "NEXT_TEST_WASM_DIR=node_modules/@next/swc-wasm-nodejs next build",
    "start": "next start",
    "lint": "tsc --noEmit",
    "vercel:build": "vercel build --non-interactive"
  },
  "dependencies": {
    "lucide-react": "^1.16.0",
    "next": "^15.5.18",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@next/swc-wasm-nodejs": "^15.5.18",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "npm": "^11.15.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vercel": "^54.4.1"
  },
  "overrides": {
    "postcss": "$postcss"
  }
}
